{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisp.dev/schemas/tool-capabilities-v1.schema.json",
  "title": "AISP Tool Capabilities (v1)",
  "description": "Optional registry/runtime declaration of tool permission hardness and risk.",
  "type": "object",
  "required": ["tool_capabilities_version", "tools"],
  "additionalProperties": true,
  "properties": {
    "tool_capabilities_version": { "const": "1.0" },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "generated_by": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string", "minLength": 1 },
        "registry": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["risk_level", "enforcement"],
        "additionalProperties": true,
        "properties": {
          "risk_level": { "enum": ["low", "medium", "high", "critical"] },
          "enforcement": { "enum": ["hard", "advisory", "unknown"] },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "forbidden_capabilities": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
